# TheRock workspace direnv configuration.
# Activates the project venv and sets workspace env vars.

# Create venv if it doesn't exist.
if [[ ! -d .venv ]]; then
    echo "Creating TheRock Python venv..."
    python3 -m venv .venv
    .venv/bin/pip install --upgrade pip
    .venv/bin/pip install \
        pyyaml \
        cmake \
        ninja
fi

# Activate venv.
source .venv/bin/activate

# Workspace env.
export THEROCK_WORKSPACE="$(pwd)"
export THEROCK_CACHE_DIR="${THEROCK_WORKSPACE}/cache"

# Local temp directory — keeps all scratch inside the workspace.
export TMPDIR="${THEROCK_WORKSPACE}/.tmp"
export TEMP="$TMPDIR"
export TMP="$TMPDIR"
mkdir -p "$TMPDIR"

# Make tools available.
export PATH="${THEROCK_WORKSPACE}/tools:${PATH}"
